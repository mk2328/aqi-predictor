# ══════════════════════════════════════════════════════════
# AQI-PREDICTOR — Environment Variables
# ══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# Add ALL of these as GitHub Actions Secrets too.
#
#   Repo → Settings → Secrets and variables → Actions → New repository secret
# ══════════════════════════════════════════════════════════

# ── OpenWeather API ────────────────────────────────────────
# Get yours at: https://openweathermap.org/api
# Used by: feature_pipeline.py, backfill_pipeline.py
OPENWEATHER_TOKEN=your_openweather_api_key_here

# ── AQICN (World Air Quality Index) API ───────────────────
# Get yours at: https://aqicn.org/data-platform/token/
# Used by: backfill_pipeline.py
AQICN_TOKEN=your_aqicn_token_here

# ── Supabase ───────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
# Use the SERVICE ROLE key (not anon) for pipelines
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# ── Streamlit Dashboard ────────────────────────────────────
# URL where your FastAPI (api.py) is running
# Local development: http://localhost:8000
# Production: https://your-api-domain.com
API_BASE_URL=http://localhost:8000
